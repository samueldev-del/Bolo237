# Backend Bolo237 appele par le portail admin.
NEXT_PUBLIC_API_URL=https://api-237jobs.onrender.com

# Authentification du portail admin.
ADMIN_PASSWORD=change-me-admin-password
ADMIN_SESSION_SECRET=change-me-with-a-long-random-secret

# Compte backend technique utilise par le proxy admin.
ADMIN_BACKEND_EMAIL=admin@bolo237.com
ADMIN_BACKEND_PASSWORD=change-me-backend-password

# Allowlist IP optionnelle.
# Si tu voyages beaucoup, laisse vide et repose-toi sur ADMIN_PASSWORD.
# Si tu veux activer un filtrage IP plus tard, renseigne une ou plusieurs IP publiques separees par des virgules.
ADMIN_ALLOWED_IPS=

# Sentry browser/server monitoring.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
