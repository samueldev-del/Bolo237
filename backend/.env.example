# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated list of allowed origins, optional)
# Example: CORS_ALLOWED_ORIGINS=https://www.bolo237.com,https://admin.bolo237.com
CORS_ALLOWED_ORIGINS=

# OTP
MASTER_OTP=0000

# Auth session cookie (required in production)
SESSION_JWT_SECRET=change-me-strong-random-secret

# Twilio WhatsApp (optional)
# Example values:
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+2376XXXXXXXX
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
