NODE_ENV=development
PORT=5000
HOST=

# Core database/session configuration.
# Connexion runtime - role least-privilege (api_worker).
# DML uniquement : SELECT/INSERT/UPDATE/DELETE. Aucun privilege DDL.
# C'est cette URL que le backend Express utilise pour servir les requetes.
DATABASE_URL=postgresql://api_worker:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require

# Connexion migrations - role owner (neondb_owner).
# DDL complet : CREATE/ALTER/DROP. Utilisee UNIQUEMENT par prisma migrate
# au demarrage du conteneur (cf. backend/package.json:prestart).
# En dev local, peut etre identique a DATABASE_URL si tu n'as pas cree api_worker.
DATABASE_MIGRATION_URL=postgresql://neondb_owner:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
SESSION_JWT_SECRET=<long_random_secret>
MASTER_OTP=

# Public origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOW_VERCEL_PREVIEW_ORIGINS=false
PUBLIC_WEB_URL=https://www.bolo237.com

# Transactional email and internal alerts.
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@bolo237.com
ADMIN_INTERNAL_ALERT_EMAILS=
ADMIN_INTERNAL_ALERT_WHATSAPP_TO=

# Admin inbox / IMAP sync.
EMAIL_IMAP_HOST=imap.hostinger.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=

# Twilio SMS / WhatsApp.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=

# Cloudinary uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Translate API.
GOOGLE_TRANSLATE_API_KEY=

# Dedicated rate-limit overrides.
SIGNUP_IP_DAILY_LIMIT=3
VERIFICATION_SUBMISSION_DAILY_LIMIT=6
CANDIDATE_PROFILE_HOURLY_LIMIT=20
SAVED_JOBS_15M_LIMIT=120
JOB_APPLICATION_HOURLY_LIMIT=30
JOB_CREATION_DAILY_LIMIT=12
APP_FEEDBACK_DAILY_LIMIT=5
USER_REVIEW_DAILY_LIMIT=12
UPLOAD_IP_15M_LIMIT=25
OTP_VERIFY_15M_LIMIT=10

# Sentry monitoring.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_RELEASE=
