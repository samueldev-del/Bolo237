// Configuration de base
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

enum Role {
  CANDIDAT
  ENTREPRISE
  ARTISAN
  ADMIN
  SUPER_ADMIN
}

enum JobStatus {
  PENDING
  ACTIVE
  APPROVED
  REJECTED
  CLOSED
  ARCHIVED
}

enum ReportStatus {
  OPEN
  REVIEWED
  CLOSED
  REJECTED
}

enum ReportTargetType {
  JOB
  USER
  COMMENT
  MESSAGE
  OTHER
}

enum JobAlertFrequency {
  DAILY
  WEEKLY
}

// 1. Table des Utilisateurs
model User {
  id               Int                 @id @default(autoincrement())
  email            String              @unique
  password         String
  name             String?
  // PII chiffrée au repos (AES-256-GCM, cf. backend/lib/crypto.js).
  // Phase A : `phone` reste en clair pour rétro-compat. Phase B : code lit
  // `phoneEnc` quand présent et `phoneHash` pour les findUnique. Phase C :
  // `phone` peut être dropé après backfill complet via scripts/encrypt-phones.js.
  phone            String?             @unique
  phoneEnc         String?
  phoneHash        String?             @unique
  photoUrl         String?
  bio_fr           String?             @db.Text
  bio_en           String?             @db.Text
  contactClicks    Int                 @default(0)
  role             Role                @default(CANDIDAT)
  isVerified       Boolean             @default(false)
  isBanned         Boolean             @default(false)
  bannedAt         DateTime?
  banReason        String?
  // Soft-delete RGPD : `deletedAt` non-null marque la suppression demandée par
  // l'utilisateur. Les données PII sont anonymisées immédiatement par
  // /api/users/me/delete ; la purge définitive intervient après 30 jours via
  // backend/cron/purgeDeletedUsers.js (droit à l'effacement RGPD art. 17).
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
  jobs             Job[]
  notifications    Notification[]
  privacyRequests  PrivacyRequest[]
  appFeedbacks     AppFeedback[]
  reviewsGiven     UserReview[]        @relation("reviewer")
  reviewsReceived  UserReview[]        @relation("reviewed")
  candidateProfile CandidateProfile?
  contactEvents    ContactClickEvent[]
  applications     Application[]
  services         ArtisanService[]
  portfolio        ArtisanPortfolio[]
  userProfile      UserProfile?
  savedJobs        SavedJob[]
  jobAlerts        JobAlert[]

  @@index([createdAt])
  @@index([role, createdAt])
  @@index([role, isVerified])
  @@index([role, isVerified, createdAt])
  @@index([isBanned, bannedAt])
  @@index([deletedAt])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_name_trgm_idx")
  @@index([email(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_email_trgm_idx")
  @@index([phone(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_phone_trgm_idx")
}

model JobAlert {
  id         Int               @id @default(autoincrement())
  userId     Int
  keywords   String
  location   String?
  frequency  JobAlertFrequency @default(DAILY)
  isActive   Boolean           @default(true)
  lastSentAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, frequency])
  @@index([createdAt])
  @@index([keywords(ops: raw("gin_trgm_ops"))], type: Gin, map: "JobAlert_keywords_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "JobAlert_location_trgm_idx")
}

model ArtisanService {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  description String?  @db.Text
  // `price` reste un texte libre (rétro-compat : "5000 FCFA / heure", "À partir de 10000"…).
  // `priceAmount` est la valeur numérique exacte pour les calculs/filtres.
  price       String?
  priceAmount Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "ArtisanService_name_trgm_idx")
}

model ArtisanPortfolio {
  id        Int      @id @default(autoincrement())
  userId    Int
  imageUrl  String
  title     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// 2. Table des Offres d'Emploi
model Job {
  id           Int           @id @default(autoincrement())
  reference    String?       @unique
  slug         String?       @unique
  externalApplyUrl String?
  logoUrl      String?
  title        String
  titleFr      String?
  titleEn      String?
  title_fr     String?
  title_en     String?
  company      String
  location     String
  description  String
  descriptionFr String?
  descriptionEn String?
  description_fr String?     @db.Text
  description_en String?     @db.Text
  salary       String?
  status       JobStatus     @default(PENDING)
  verified     Boolean       @default(false)
  sourceType   String?
  sourceUrl    String?
  sourceHash   String?       @unique
  outreachEmailSentAt DateTime?
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId     Int
  // Soft-delete : utilisé pour archiver une offre sans rompre les candidatures.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  viewCount    Int           @default(0)
  applyClickCount Int       @default(0)
  applications Application[]
  savedJobs    SavedJob[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([authorId, createdAt])
  @@index([slug])
  @@index([deletedAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_title_trgm_idx")
  @@index([company(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_company_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_location_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_description_trgm_idx")
}

// 3. Table des Signalements (Pour la sécurité)
model Report {
  id         Int              @id @default(autoincrement())
  reason     String
  targetType ReportTargetType
  targetId   Int
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId, status])
}

model Notification {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Notification_title_trgm_idx")
  @@index([message(ops: raw("gin_trgm_ops"))], type: Gin, map: "Notification_message_trgm_idx")
  @@index([type(ops: raw("gin_trgm_ops"))], type: Gin, map: "Notification_type_trgm_idx")
}

model PrivacyRequest {
  id             Int       @id @default(autoincrement())
  reference      String    @unique
  kind           String
  status         String    @default("PENDING")
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         Int?
  requesterEmail String
  requesterPhone String?
  requesterRole  String?
  requesterName  String?
  reason         String?
  delivery       String?
  sourceIp       String?
  userAgent      String?
  notes          String?
  payload        Json?
  requestedAt    DateTime  @default(now())
  processedAt    DateTime?
  processedBy    String?
  updatedAt      DateTime  @updatedAt

  @@index([status, requestedAt])
  @@index([kind, requestedAt])
  @@index([userId, requestedAt])
  @@index([reference(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_reference_trgm_idx")
  @@index([requesterEmail(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterEmail_trgm_idx")
  @@index([requesterName(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterName_trgm_idx")
  @@index([requesterPhone(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterPhone_trgm_idx")
  @@index([requesterRole(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterRole_trgm_idx")
  @@index([reason(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_reason_trgm_idx")
  @@index([notes(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_notes_trgm_idx")
  @@index([processedBy(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_processedBy_trgm_idx")
}

model AppFeedback {
  id         Int      @id @default(autoincrement())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     Int?
  authorName String?
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

model UserReview {
  id         Int      @id @default(autoincrement())
  reviewer   User     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId Int
  reviewed   User     @relation("reviewed", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewedId Int
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  @@index([reviewedId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([createdAt])
}

model CandidateProfile {
  id            Int      @id @default(autoincrement())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId        Int?     @unique
  nom           String
  titre         String
  localisation  String   @default("Douala")
  experience    String   @default("Confirme")
  disponibilite String   @default("Immediatement")
  etudes        String   @default("Bac+3")
  competences   String[] @default([])
  disponibleNow Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([localisation])
  @@index([experience, createdAt])
  @@index([disponibilite, createdAt])
  @@index([etudes, createdAt])
  @@index([disponibleNow, createdAt])
  @@index([competences], type: Gin)
}

model UserProfile {
  userId         Int      @id
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String   @default("")
  title          String   @default("")
  location       String   @default("")
  availability   String   @default("")
  profileVisible Boolean  @default(true)
  jobAlertRole   String   @default("")
  jobAlertCity   String   @default("")
  phone          String   @default("")
  email          String   @default("")
  profile        String   @default("")
  defaultCvUrl   String   @default("")
  experience     String   @default("")
  education      String   @default("")
  skillsText     String   @default("")
  languagesText  String   @default("")
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([updatedAt])
  @@index([defaultCvUrl])
  @@index([profileVisible, updatedAt])
}

model ContactClickEvent {
  id        Int      @id @default(autoincrement())
  artisan   User     @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  artisanId Int
  createdAt DateTime @default(now())

  @@index([artisanId, createdAt])
  @@index([createdAt])
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  userId    Int
  jobId     Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId],  references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, createdAt])
  @@index([jobId])
}

model VerificationSubmission {
  id          String    @id @default(cuid())
  role        String
  accountKey  String
  displayName String
  // Phase A : `phone` reste en clair pour rétro-compat. Phase B : code écrit
  // `phoneEnc` (AES-256-GCM) et `phoneHash` (HMAC pour les recherches).
  // `payload` peut contenir des images de doc d'identité encodées : à terme
  // chiffrer via une migration séparée si critique RGPD.
  phone       String
  phoneEnc    String?
  phoneHash   String?
  status      String    @default("pending")
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  notes       String?
  payload     Json

  @@unique([role, accountKey])
  @@index([submittedAt])
  @@index([status, submittedAt])
  @@index([phone, submittedAt])
  @@index([phoneHash])
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  // PHASE A transitoire : `code` reste rempli en parallèle de `codeHash` pour
  // permettre un rollback rapide. À supprimer en phase B après bascule complète.
  code      String?
  codeHash  String?
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model RevokedSession {
  jti       String   @id
  expiresAt DateTime
  revokedAt DateTime @default(now())

  @@index([expiresAt])
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  messageId   String?  @unique
  imapUid     Int?
  mailboxPath String   @default("INBOX")
  senderEmail String // L'adresse de celui qui t'ecrit
  senderName  String? // Son nom (s'il est detecte)
  subject     String // L'objet du mail
  body        String // Le contenu du message
  attachments Json?
  status      String   @default("UNREAD") // Statuts : UNREAD, READ, REPLIED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mailboxPath, createdAt])
  @@index([mailboxPath, status])
}

model Application {
  id          Int      @id @default(autoincrement())
  jobId       Int
  candidateId Int
  message     String   @db.Text
  cvUrl       String
  status      String   @default("APPLIED") // Ex: APPLIED, REVIEWING, INTERVIEW, REJECTED, HIRED
  // Soft-delete : permet au candidat de retirer une candidature sans
  // perdre les statistiques de recrutement côté entreprise.
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate User @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // 🛡️ Double sécurité Anti-Spam directement dans la BDD (Un candidat ne peut postuler qu'une seule fois à une offre)
  @@unique([jobId, candidateId])
  @@index([candidateId, createdAt])
  @@index([jobId, status])
  @@index([status, createdAt])
}
