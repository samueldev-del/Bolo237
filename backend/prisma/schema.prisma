// Configuration de base
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

enum Role {
  CANDIDAT
  ENTREPRISE
  ARTISAN
  ADMIN
  SUPER_ADMIN
}

enum JobStatus {
  PENDING
  ACTIVE
  APPROVED
  REJECTED
  CLOSED
  ARCHIVED
}

// 1. Table des Utilisateurs
model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  name             String?
  phone            String?           @unique
  photoUrl         String?
  contactClicks    Int               @default(0)
  role             Role              @default(CANDIDAT)
  isVerified       Boolean           @default(false)
  isBanned         Boolean           @default(false)
  bannedAt         DateTime?
  banReason        String?
  createdAt        DateTime          @default(now())
  jobs             Job[]
  notifications    Notification[]
  privacyRequests  PrivacyRequest[]
  appFeedbacks     AppFeedback[]
  reviewsGiven     UserReview[]      @relation("reviewer")
  reviewsReceived  UserReview[]      @relation("reviewed")
  candidateProfile CandidateProfile?
  contactEvents    ContactClickEvent[]

  @@index([createdAt])
  @@index([role, createdAt])
  @@index([role, isVerified])
  @@index([isBanned, bannedAt])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_name_trgm_idx")
  @@index([email(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_email_trgm_idx")
  @@index([phone(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_phone_trgm_idx")
}

// 2. Table des Offres d'Emploi
model Job {
  id          Int       @id @default(autoincrement())
  title       String
  company     String
  location    String
  description String
  salary      String?
  status      JobStatus @default(PENDING)
  author      User      @relation(fields: [authorId], references: [id])
  authorId    Int
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([authorId, createdAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_title_trgm_idx")
  @@index([company(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_company_trgm_idx")
  @@index([location(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_location_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "Job_description_trgm_idx")
}

// 3. Table des Signalements (Pour la sécurité)
model Report {
  id         Int      @id @default(autoincrement())
  reason     String
  targetType String
  targetId   Int
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([targetType, targetId, status])
}

model Notification {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "Notification_title_trgm_idx")
  @@index([message(ops: raw("gin_trgm_ops"))], type: Gin, map: "Notification_message_trgm_idx")
  @@index([type(ops: raw("gin_trgm_ops"))], type: Gin, map: "Notification_type_trgm_idx")
}

model PrivacyRequest {
  id             Int       @id @default(autoincrement())
  reference      String    @unique
  kind           String
  status         String    @default("PENDING")
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         Int?
  requesterEmail String
  requesterPhone String?
  requesterRole  String?
  requesterName  String?
  reason         String?
  delivery       String?
  sourceIp       String?
  userAgent      String?
  notes          String?
  payload        Json?
  requestedAt    DateTime  @default(now())
  processedAt    DateTime?
  processedBy    String?
  updatedAt      DateTime  @updatedAt

  @@index([status, requestedAt])
  @@index([kind, requestedAt])
  @@index([userId, requestedAt])
  @@index([reference(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_reference_trgm_idx")
  @@index([requesterEmail(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterEmail_trgm_idx")
  @@index([requesterName(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterName_trgm_idx")
  @@index([requesterPhone(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterPhone_trgm_idx")
  @@index([requesterRole(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_requesterRole_trgm_idx")
  @@index([reason(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_reason_trgm_idx")
  @@index([notes(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_notes_trgm_idx")
  @@index([processedBy(ops: raw("gin_trgm_ops"))], type: Gin, map: "PrivacyRequest_processedBy_trgm_idx")
}

model AppFeedback {
  id         Int      @id @default(autoincrement())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     Int?
  authorName String?
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model UserReview {
  id         Int      @id @default(autoincrement())
  reviewer   User     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId Int
  reviewed   User     @relation("reviewed", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewedId Int
  rating     Int
  comment    String
  createdAt  DateTime @default(now())

  @@index([reviewedId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([createdAt])
}

model CandidateProfile {
  id            Int      @id @default(autoincrement())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId        Int?     @unique
  nom           String
  titre         String
  localisation  String   @default("Douala")
  experience    String   @default("Confirme")
  disponibilite String   @default("Immediatement")
  etudes        String   @default("Bac+3")
  competences   String[] @default([])
  disponibleNow Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model UserProfile {
  userId        Int      @id
  fullName      String   @default("")
  title         String   @default("")
  location      String   @default("")
  availability  String   @default("")
  profileVisible Boolean @default(true)
  jobAlertRole  String   @default("")
  jobAlertCity  String   @default("")
  phone         String   @default("")
  email         String   @default("")
  profile       String   @default("")
  experience    String   @default("")
  education     String   @default("")
  skillsText    String   @default("")
  languagesText String   @default("")
  updatedAt     DateTime @default(now()) @updatedAt
}

model ContactClickEvent {
  id        Int      @id @default(autoincrement())
  artisan   User     @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  artisanId Int
  createdAt DateTime @default(now())

  @@index([artisanId, createdAt])
  @@index([createdAt])
}

model SavedJob {
  id     Int @id @default(autoincrement())
  userId Int
  jobId  Int

  @@unique([userId, jobId])
  @@index([userId])
}

model VerificationSubmission {
  id          String    @id @default(cuid())
  role        String
  accountKey  String
  displayName String
  phone       String
  status      String    @default("pending")
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  notes       String?
  payload     Json

  @@unique([role, accountKey])
  @@index([submittedAt])
  @@index([status, submittedAt])
  @@index([phone, submittedAt])
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model RevokedSession {
  jti       String   @id
  expiresAt DateTime
  revokedAt DateTime @default(now())

  @@index([expiresAt])
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  messageId   String?  @unique
  imapUid     Int?
  mailboxPath String   @default("INBOX")
  senderEmail String // L'adresse de celui qui t'ecrit
  senderName  String? // Son nom (s'il est detecte)
  subject     String // L'objet du mail
  body        String // Le contenu du message
  attachments Json?
  status      String   @default("UNREAD") // Statuts : UNREAD, READ, REPLIED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mailboxPath, createdAt])
  @@index([mailboxPath, status])
}
