# URL publique du backend Bolo237 utilisee par le navigateur et par les routes server-side.
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL interne optionnelle si le frontend tourne en conteneur et doit appeler un backend sur une autre adresse.
BACKEND_INTERNAL_URL=http://localhost:5000

# Integrations serveur optionnelles.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PDF_SERVICE_URL=https://your-render-puppeteer-service/render-pdf

# Sentry browser/server monitoring.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1
SENTRY_TRACES_SAMPLE_RATE=1
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
