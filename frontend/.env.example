# URL publique du backend Bolo237 utilisee par le navigateur et par les routes server-side.
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL interne optionnelle si le frontend tourne en conteneur et doit appeler un backend sur une autre adresse.
BACKEND_INTERNAL_URL=http://localhost:5000

# Integrations serveur optionnelles.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PDF_SERVICE_URL=https://your-render-puppeteer-service/render-pdf
